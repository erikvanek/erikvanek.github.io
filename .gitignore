# ── Dependencies / build noise ───────────────────────────────
node_modules
.DS_Store
yarn-error.log

# ── Secrets: NEVER commit (they belong in 1Password) ─────────
*.env
*.env.*
.env
.env.*
!*.env.example          # allow documented examples (no real values)
*.key
*.pem
*.pfx
*.p12
# Obsidian plugin data files can hold API keys / private keys
**/.obsidian/plugins/*/data.json

# ── Obsidian vault internals: never publish editor/tool config ─
**/.obsidian/
**/.smart-env/
**/.claude/

# ── Private PARA folders: kept in a separate private repo, never here ─
# (generic category names only; restores protection that must not be lost)
pages/notes/10 - 🧠 Knowledge/1 - 🚀 Projects/
pages/notes/10 - 🧠 Knowledge/4 - 🏛️ Archives/
