<!DOCTYPE html>
<html lang="cs" data-theme="light">
    <head>
        <meta charset="utf-8"/>
        <title>{{ title }}</title>
        <meta name="description" content="{{ description }}"/>
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
        <link rel="stylesheet" href="/fonts/fonts.css"/>
        <link rel="stylesheet" href="/css/pico.classless.min.css"/>
        <link rel="stylesheet" href="/css/dis-article.css"/>
        <link rel="shortcut icon" type="image/x-icon" href="/icon.png"/>
        <script>
          /* Deep-linked headings (e.g. the cesta cards → /…/#design-kantyna,
             /…/cile-VI/#ux-monday) should glide into view, not jump. Strip the
             hash before first paint so the browser doesn't jump, then smooth-
             scroll to it once the page (and its images) have loaded. Self-
             contained on purpose — no external file to half-load. */
          (function () {
            var hash = window.location.hash;
            if (!hash || hash.length < 2) return;
            try { history.replaceState(null, '', window.location.pathname + window.location.search); } catch (e) { /* noop */ }
            var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            function go() {
              var id;
              try { id = decodeURIComponent(hash.slice(1)); } catch (e) { id = hash.slice(1); }
              var el = document.getElementById(id);
              try { history.replaceState(null, '', hash); } catch (e) { /* noop */ }
              if (!el) return;
              try { el.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'start' }); }
              catch (e) { window.location.hash = hash; }
            }
            window.addEventListener('load', go);
          })();
        </script>
    </head>

    {% include "_analytics.html" %}

    <body>
        <div class="progress" aria-hidden="true"><span class="progress__fill"></span><span class="progress__done"></span></div>

        <main id="wrapper">
            {% if hideTitle !== true %}
                <a href="/dis-kisk/" class="back">← Cesta studiem</a>
                <header class="article-head">
                    <h1>{{ title }}</h1>
                    {% if subtitle %}
                        <p class="subtitle">{{ subtitle }}</p>
                    {% endif %}
                    {% set sem = tags | semNum %}
                    {% if sem %}
                        <div class="article-meta">
                            <span class="am-date">{{ date | czDate }}</span>
                            <span class="am-sep">·</span>
                            <span class="am-sem">{{ sem }}. semestr</span>
                            <span class="am-sep">·</span>
                            <span class="am-type">{% if praxe %}Praxe{% else %}{{ page.fileSlug | artType }}{% endif %}</span>
                        </div>
                    {% endif %}
                </header>
            {% endif %}

            <article>
                {{ content | safe }}
            </article>
        </main>

        <script src="/js/progress.js" defer></script>
        <script src="/js/rough.js" defer></script>
        <script src="/js/journey.js" defer></script>
        <script src="/js/dis-flourish.js" defer></script>
    </body>
</html>
